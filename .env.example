# Copy to .env.local for local dev, and set the same variables in Vercel
# (Project → Settings → Environment Variables).

# Which AI provider powers the chat: "anthropic" or "openai".
# If you leave this empty, the app auto-detects from whichever key is set below.
AI_PROVIDER=anthropic

# --- Anthropic (Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
